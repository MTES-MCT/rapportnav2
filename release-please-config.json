{
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "rapportnav",
      "components": ["rapportnav", "backend", "frontend"],
      "merge": true
    }
  ],
  "separate-pull-requests": false,
  "commit-search-depth": 50,
  "release-search-depth": 50,
  "always-link-local": true,
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "draft": false,
  "prerelease": false,
  "pull-request-header": "🤖 Release created:",
  "pull-request-footer": "_release-please generated PR_",
  "pull-request-title-pattern": "chore: release v${version}",
  "packages": {
    ".": {
      "component": "rapportnav",
      "release-type": "simple",
      "extra-files": [
        {
          "type": "yaml",
          "path": ".gitlab-ci.yml",
          "jsonpath": "$.variables.PROJECT_VERSION.value"
        }
      ],
      "exclude-paths": ["frontend/*", "backend/*"]
    },
    "backend": {
      "component": "backend",
      "release-type": "simple",
      "skip-github-release": true,
      "extra-files": [
        {
          "type": "generic",
          "path": "build.gradle.kts"
        }
      ]
    },
    "frontend": {
      "component": "frontend",
      "release-type": "node",
      "skip-github-release": true
    }
  },
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json"
}
